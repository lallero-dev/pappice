# Copy this file to .env for local development or deployment tooling.
# Do not commit real SMTP credentials.

# HTTP/TLS
PEMMECE_ADDR=127.0.0.1:8388
PEMMECE_DB=./pemmece.db
PEMMECE_TLS_CERT=./localhost.pem
PEMMECE_TLS_KEY=./localhost-key.pem
PEMMECE_SESSION_TTL=336h
PEMMECE_LOGIN_RATE_LIMIT=10
PEMMECE_LOGIN_RATE_WINDOW=1m
PEMMECE_ACCOUNT_LINK_RATE_LIMIT=10
PEMMECE_ACCOUNT_LINK_RATE_WINDOW=1m

# Instance branding.
PEMMECE_BRAND_NAME=Pemmece
PEMMECE_BRAND_SUBTITLE=customer support
PEMMECE_BRAND_MARK=P
PEMMECE_BRAND_COLOR=#5bb974

# Public HTTPS URL used in no-reply email links.
PEMMECE_PUBLIC_URL=https://127.0.0.1:8388

# Email notifications. Keep disabled until SMTP is configured.
PEMMECE_EMAIL_NOTIFICATIONS=false
PEMMECE_SMTP_HOST=
PEMMECE_SMTP_PORT=587
PEMMECE_SMTP_USER=
PEMMECE_SMTP_PASSWORD=
PEMMECE_SMTP_FROM=no-reply@example.com
PEMMECE_SMTP_TLS_MODE=starttls
PEMMECE_EMAIL_BATCH_DELAY=20s

# Development-only webhook escape hatches. Keep both false in production.
PEMMECE_ALLOW_INSECURE_WEBHOOKS=false
PEMMECE_ALLOW_PRIVATE_WEBHOOKS=false
