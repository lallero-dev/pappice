# Pemmece runtime configuration.
# Copy this file to .env for local process managers or deployment tooling.
# Do not commit real SMTP credentials.

# HTTP/TLS
PEMMECE_ADDR=127.0.0.1:8388
PEMMECE_DB=./pemmece.db
PEMMECE_TLS_CERT=./localhost.pem
PEMMECE_TLS_KEY=./localhost-key.pem

# Public URL used in no-reply email links.
# Use the real HTTPS URL in production, for example:
# PEMMECE_PUBLIC_URL=https://support.example.com
PEMMECE_PUBLIC_URL=https://127.0.0.1:8388

# Email notifications.
# Email is enabled when SMTP host and from address are configured.
PEMMECE_EMAIL_NOTIFICATIONS=false
PEMMECE_SMTP_HOST=
PEMMECE_SMTP_PORT=587
PEMMECE_SMTP_USER=
PEMMECE_SMTP_PASSWORD=
PEMMECE_SMTP_FROM=no-reply@example.com
PEMMECE_SMTP_TLS_MODE=starttls
# Coalesces multiple ticket changes for the same recipient before sending.
PEMMECE_EMAIL_BATCH_DELAY=20s

# Development-only webhook escape hatches.
# Keep both false in production.
PEMMECE_ALLOW_INSECURE_WEBHOOKS=false
PEMMECE_ALLOW_PRIVATE_WEBHOOKS=false
