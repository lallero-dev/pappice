# Docker deployment template. Copy to deploy/docker/pappice.env.

PAPPICE_ADDR=0.0.0.0:8388
PAPPICE_PUBLIC_URL=https://support.example.com

PAPPICE_DB=/data/pappice.db
PAPPICE_UPLOAD_DIR=/data/uploads
PAPPICE_BACKUP_DIR=/backups

# The public reverse proxy terminates TLS and forwards requests over HTTP.
# Only enable this when Pappice is not directly exposed to the internet.
PAPPICE_TRUST_PROXY_HEADERS=true
PAPPICE_TLS_CERT=
PAPPICE_TLS_KEY=

PAPPICE_SESSION_TTL=336h
PAPPICE_LOGIN_RATE_LIMIT=10
PAPPICE_LOGIN_RATE_WINDOW=1m
PAPPICE_ACCOUNT_LINK_RATE_LIMIT=10
PAPPICE_ACCOUNT_LINK_RATE_WINDOW=1m
PAPPICE_DOMAIN_EVENT_RETENTION=720h

PAPPICE_BRAND_NAME=Pappice
PAPPICE_BRAND_SUBTITLE=customer support
PAPPICE_BRAND_MARK=P
PAPPICE_BRAND_COLOR=#5bb974

PAPPICE_MAX_UPLOAD_SIZE=10485760
PAPPICE_MAX_UPLOAD_FILES=5
PAPPICE_ALLOWED_UPLOAD_TYPES=image/png,image/jpeg,image/gif,image/webp,application/pdf,application/json,application/zip,text/plain,text/csv

# Email notifications. Keep disabled until SMTP is configured.
PAPPICE_EMAIL_NOTIFICATIONS=false
PAPPICE_SMTP_HOST=
PAPPICE_SMTP_PORT=587
PAPPICE_SMTP_USER=
PAPPICE_SMTP_PASSWORD=
PAPPICE_SMTP_FROM=no-reply@support.example.com
PAPPICE_SMTP_TLS_MODE=starttls
PAPPICE_NOTIFICATION_DELAY=30s

# Production webhook policy. Keep both false.
PAPPICE_ALLOW_INSECURE_WEBHOOKS=false
PAPPICE_ALLOW_PRIVATE_WEBHOOKS=false
